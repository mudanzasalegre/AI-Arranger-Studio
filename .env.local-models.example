# Copy manually into .env or merge with your existing .env.
# Do not commit real secrets, private paths, local checkpoints or private dataset paths.

APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
WEB_PORT=3000

# Existing API storage used by apps/api.
AI_ARRANGER_API_STORAGE=./outputs/api

# AI model configs.
AI_MODELS_CONFIG=./configs/ai_models.local.yaml
LOCAL_MODEL_RUNTIME_CONFIG=./configs/local_model_runtime.yaml
MODEL_REGISTRY_CONFIG=./configs/model_registry.yaml

# Local model/cache roots.
AI_MODELS_ROOT=./models
HF_HOME=./models/hf_cache
HF_HUB_CACHE=./models/hf_cache/hub
HF_ASSETS_CACHE=./models/hf_cache/assets
HF_HUB_OFFLINE=0
HF_HUB_DISABLE_TELEMETRY=1

# Device selection: auto | cpu | cuda | mps
AI_DEVICE=auto

# Optional model worker.
AI_MODEL_WORKER_URL=http://127.0.0.1:8010
AI_MODEL_WORKER_ENABLED=false

# Backend feature flags.
AI_ENABLE_MOCK_SYMBOLIC=true
AI_ENABLE_MIDIGPT=false
AI_ENABLE_TEXT2MIDI=false
AI_ENABLE_LOCAL_LLM_PLANNER=false
AI_ENABLE_CUSTOM_ROLE_MODELS=false

# MIDI-GPT.
MIDIGPT_MODEL_NAME=yellow
MIDIGPT_LOCAL_CHECKPOINT=
MIDIGPT_CACHE=./models/hf_cache/midigpt

# Text2MIDI.
TEXT2MIDI_REPO_DIR=./models/external_repos/text2midi
TEXT2MIDI_CHECKPOINT_DIR=./models/checkpoints/text2midi
TEXT2MIDI_MODEL_FILE=./models/checkpoints/text2midi/pytorch_model.bin
TEXT2MIDI_TOKENIZER_FILE=./models/checkpoints/text2midi/vocab_remi.pkl

# Local planner via Ollama.
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_PLANNER_MODEL=qwen3:8b
OLLAMA_REQUEST_TIMEOUT_SECONDS=120

# Training.
TRAINING_DATA_ROOT=./data/processed/training
TOKENIZED_DATA_ROOT=./data/processed/tokenized
CUSTOM_MODEL_ROOT=./models/checkpoints/custom
