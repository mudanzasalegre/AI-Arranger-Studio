# Copy this file to .env for local-only configuration.
# Do not commit real secrets, private paths, or API tokens.

APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
WEB_PORT=3000

# Optional local storage override. Leave empty to use the project default.
ARRANGER_STORAGE_DIR=

# Optional model provider keys. Heavy model files stay outside Git.
OPENAI_API_KEY=
MIDIGPT_MODEL_PATH=
TEXT2MIDI_MODEL_PATH=
